{
  "_title": "Agent Task Board",
  "_icon": "🔮",
  "_layout": "table",
  "_listField": "tasks",
  "_primaryKey": "id",
  "id": { "label": "ID", "readOnly": true, "width": "50px" },
  "title": { "label": "Task", "type": "text", "width": "250px" },
  "status": {
    "label": "Status",
    "type": "badge",
    "options": ["Open", "In Progress", "Review", "Done"],
    "badgeColors": {
      "Open": "#3b82f6",
      "In Progress": "#f59e0b",
      "Review": "#a855f7",
      "Done": "#22c55e"
    },
    "width": "110px"
  },
  "priority": {
    "label": "Priority",
    "type": "select",
    "options": ["Low", "Medium", "High", "Critical"],
    "width": "100px"
  },
  "assignee": { "label": "Agent", "type": "text", "width": "130px" },
  "created": { "label": "Created", "type": "date", "width": "120px" },
  "notes": { "label": "Notes", "type": "text" }
}
