      "text": "<body>\n\n<!-- Setup Screen -->\n<div id=\"setupScreen\" style=\"display: none;\">\n  <div class=\"setup-title\">PulseOS Chat</div>\n  <div class=\"setup-sub\">Verbinde dich mit einem PulseOS User</div>\n  <input class=\"setup-input\" id=\"nameInput\" placeholder=\"Dein Name\" maxlength=\"30\">\n  <input class=\"setup-input\" id=\"avatarInput\" placeholder=\"Avatar (1 Emoji)\" maxlength=\"4\" value=\"👤\" style=\"width:80px;\">\n  <div class=\"setup-divider\"></div>\n  <input class=\"setup-input\" id=\"roomInput\" placeholder=\"Raum-Code (z.B. pulse-56d8fb24)\">\n  <button class=\"setup-btn\" id=\"joinBtn\" onclick=\"joinRoom()\">Verbinden</button>\n  <div id=\"setupError\" style=\"color:#ef4444;font-size:11px;min-height:16px;\"></div>\n</div>\n\n<!-- Chat Screen -->\n<div id=\"chatScreen\" style=\"display: flex;\">\n  <div class=\"chat-topbar\">\n    <div class=\"dot online\" id=\"statusDot\"></div>\n    <span class=\"title\" id=\"roomTitle\">Raum: pulse-56d8fb24</span>\n    <span class=\"info\" id=\"peerCount\">1 online</span>\n    <button class=\"btn\" onclick=\"disconnect()\">Verlassen</button>\n  </div>\n  <div id=\"messages\"><div class=\"system-msg\">— Verbunden mit Signaling-Server —</div><div class=\"system-msg\">— Chris ist beigetreten —</div><div class=\"msg self\"><div class=\"avatar\">👤</div><div><div class=\"name\">Hein</div><div class=\"bubble\">Wortanzahl: Nimmt man eine durchschnittliche, kurze Länge von Nachrichten an, dürfte die Zahl der Wörter in die Tausende gehen, wobei viele Nachrichten sehr kurz sind (Emojis/kurze Antworten).</div></div></div><div class=\"msg peer\"><div class=\"avatar\">🧑‍💻</div><div><div class=\"name\">Chris</div><div class=\"bubble\">Wortanzahl: Nimmt man eine durchschnittliche, kurze Länge von Nachrichten an, dürfte die Zahl der Wörter in die Tausende gehen, wobei viele Nachrichten sehr kurz sind (Emojis/kurze Antworten).</div></div></div><div class=\"msg self\"><div class=\"avatar\">👤</div><div><div class=\"name\">Hein</div><div class=\"bubble\">Wortanzahl: Nimmt man eine durchschnittliche, kurze Länge von Nachrichten an, dürfte die Zahl der Wörter in die Tausende gehen, wobei viele Nachrichten sehr kurz sind (Emojis/kurze Antworten).</div></div></div></div>\n  <div class=\"input-row\">\n    <textarea id=\"chatInput\" rows=\"1\" placeholder=\"Nachricht...\" onkeydown=\"if(event.key==='Enter'&amp;&amp;!event.shiftKey){event.preventDefault();sendMsg();}\" style=\"height: auto;\"></textarea>\n    <button id=\"sendBtn\" onclick=\"sendMsg()\">▶</button>\n  </div>\n  <div class=\"powered\">Powered by <a href=\"https://github.com/NastyFFM/PulseOS\" target=\"_blank\">PulseOS</a></div>\n</div>\n\n<script src=\"https://cdn.socket.io/4.7.5/socket.io.min.js\"></script>\n<script>\nconst SIGNALING_URL = 'https://web-production-84380f.up.railway.app';\nconst ICE_SERVERS = [\n  { urls: 'stun:stun.l.google.com:19302' },\n  { urls: 'stun:stun1.l.google.com:19302' }\n];\n\nlet socket = null, roomId = null;\nlet myProfile = { name: '', avatar: '👤', handle: '' };\nconst peers = {}; // peerId → { pc, dc, profile }\nconst msgIds = new Set();\n\n// Load saved profile from localStorage\nfunction loadProfile() {\n  try {\n    const saved = JSON.parse(localStorage.getItem('pulseChat') || '{}');\n    if (saved.name) document.getElementById('nameInput').value = saved.name;\n    if (saved.avatar) document.getElementById('avatarInput').value = saved.avatar;\n    if (saved.lastRoom) document.getElementById('roomInput').value = saved.lastRoom;\n  } catch {}\n}\n\nfunction saveProfile() {\n  localStorage.setItem('pulseChat', JSON.stringify({\n    name: myProfile.name,\n    avatar: myProfile.avatar,\n    lastRoom: roomId\n  }));\n}\n\n// Check URL params for room\nfunction checkUrlParams() {\n  const params = new URLSearchParams(window.location.search);\n  const room = params.get('room');\n  if (room) document.getElementById('roomInput').value = room;\n}\n\n// Join room\nfunction joinRoom() {\n  const name = document.getElementById('nameInput').value.trim();\n  const avatar = document.getElementById('avatarInput').value.trim() || '👤';\n  const room = document.getElementById('roomInput').value.trim();\n\n  if (!name) { document.getElementById('setupError').textContent = 'Bitte Name eingeben'; return; }\n  if (!room) { document.getElementById('setupError').textContent = 'Bitte Raum-Code eingeben'; return; }\n\n  myProfile = { name, avatar, handle: name.toLowerCase().replace(/\\s+/g, '-') + '-guest' };\n  roomId = room;\n  saveProfile();\n\n  document.getElementById('setupScreen').style.display = 'none';\n  document.getElementById('chatScreen').style.display = 'flex';\n  document.getElementById('roomTitle').textContent = 'Raum: ' + roomId.substring(0, 16);\n\n  connectSocket();\n}\n\n// Socket.io + WebRTC\nfunction connectSocket() {\n  if (socket) { try { socket.disconnect(); } catch {} }\n\n  socket = io(SIGNALING_URL, {\n    forceNew: true,\n    transports: ['websocket', 'polling'],\n    reconnection: true,\n    reconnectionAttempts: Infinity,\n    reconnectionDelay: 3000\n  });\n\n  socket.on('connect', () => {\n    document.getElementById('statusDot').className = 'dot connecting';\n    socket.emit('join-room', { roomId });\n    addSystemMsg('Verbunden mit Signaling-Server');\n  });\n\n  socket.on('room-users', ({ users }) => {\n    users.forEach(id => createPeer(id, true));\n    updatePeerCount();\n  });\n\n  socket.on('user-left', ({ userId }) => {\n    const name = peers[userId]?.profile?.name || 'Peer';\n    cleanupPeer(userId);\n    addSystemMsg(name + ' hat den Raum verlassen');\n    updatePeerCount();\n  });\n\n  socket.on('offer', async ({ offer, senderId }) => {\n    const pc = createPeer(senderId, false);\n    try {\n      await pc.setRemoteDescription(offer);\n      const answer = await pc.createAnswer();\n      await pc.setLocalDescription(answer);\n      socket.emit('answer', { roomId, answer, targetId: senderId });\n    } catch (e) {\n      console.warn('Offer handling failed:', e.message);\n      cleanupPeer(senderId);\n    }\n  });\n\n  socket.on('answer', async ({ answer, senderId }) => {\n    if (peers[senderId]?.pc)\n      try { await peers[senderId].pc.setRemoteDescription(answer); } catch {}\n  });\n\n  socket.on('ice-candidate', async ({ candidate, senderId }) => {\n    if (peers[senderId]?.pc && candidate)\n      try { await peers[senderId].pc.addIceCandidate(candidate); } catch {}\n  });\n\n  socket.on('disconnect', () => {\n    document.getElementById('statusDot').className = 'dot';\n    addSystemMsg('Verbindung verloren — versuche erneut...');\n  });\n\n  socket.on('reconnect', () => {\n    socket.emit('join-room', { roomId });\n    addSystemMsg('Wieder verbunden');\n  });\n}\n\nfunction createPeer(targetId, isInitiator) {\n  if (peers[targetId]?.pc) return peers[targetId].pc;\n\n  const pc = new RTCPeerConnection({ iceServers: ICE_SERVERS });\n  peers[targetId] = { pc, dc: null, profile: null };\n\n  if (isInitiator) {\n    const dc = pc.createDataChannel('bridge', { ordered: true });\n    setupChannel(dc, targetId);\n  }\n\n  pc.ondatachannel = e => setupChannel(e.channel, targetId);\n\n  pc.onicecandidate = e => {\n    if (e.candidate && socket)\n      socket.emit('ice-candidate', { roomId, candidate: e.candidate, targetId });\n  };\n\n  pc.onconnectionstatechange = () => {\n    if (pc.connectionState === 'failed' || pc.connectionState === 'closed') {\n      const name = peers[targetId]?.profile?.name || 'Peer';\n      addSystemMsg('Verbindung zu ' + name + ' verloren');\n      cleanupPeer(targetId);\n      updatePeerCount();\n    }\n  };\n\n  if (isInitiator) {\n    pc.createOffer()\n      .then(offer => { pc.setLocalDescription(offer); socket.emit('offer', { roomId, offer, targetId }); })\n      .catch(() => cleanupPeer(targetId));\n  }\n\n  return pc;\n}\n\nfunction setupChannel(dc, targetId) {\n  peers[targetId].dc = dc;\n\n  dc.onopen = () => {\n    document.getElementById('statusDot').className = 'dot online';\n    dc.send(JSON.stringify({ type: 'profile-exchange', profile: myProfile }));\n    updatePeerCount();\n  };\n\n  dc.onclose = () => {\n    if (peers[targetId]) peers[targetId].dc = null;\n    updatePeerCount();\n  };\n\n  dc.onmessage = e => {\n    try {\n      const data = JSON.parse(e.data);\n      console.log('[DC] Received from', targetId, ':', data.type, data.text?.substring(0,30));\n      handleMessage(data, targetId);\n    } catch(err) { console.warn('[DC] Parse error:', err); }\n  };\n}\n\nfunction handleMessage(data, senderId) {\n  switch (data.type) {\n    case 'profile-exchange':\n      peers[senderId].profile = data.profile;\n      addSystemMsg((data.profile.name || 'Peer') + ' ist beigetreten');\n      updatePeerCount();\n      break;\n\n    case 'chat-message': case 'text':\n      const text = data.text || data.content;\n      if (!text) return;\n      const from = peers[senderId]?.profile?.name || 'Peer';\n      const avatar = peers[senderId]?.profile?.avatar || '?';\n      // Check if it's from ClaudeOS\n      const isAgent = data.fromAgent || data.source === 'claudeos';\n      addChatMsg(from, avatar, text, isAgent ? 'agent' : 'peer', data.id);\n      break;\n\n    case 'ping':\n      if (peers[senderId]?.dc?.readyState === 'open')\n        peers[senderId].dc.send(JSON.stringify({ type: 'pong', timestamp: data.timestamp }));\n      break;\n  }\n}\n\nfunction sendMsg() {\n  const input = document.getElementById('chatInput');\n  const text = input.value.trim();\n  if (!text) return;\n  input.value = '';\n  input.style.height = 'auto';\n\n  const msgId = 'g-' + Date.now() + Math.random().toString(36).substring(7);\n\n  // Send to all peers\n  Object.values(peers).forEach(p => {\n    if (p.dc?.readyState === 'open') {\n      p.dc.send(JSON.stringify({ type: 'chat-message', text, id: msgId, timestamp: Date.now() }));\n    }\n  });\n\n  addChatMsg(myProfile.name, myProfile.avatar, text, 'self', msgId);\n}\n\nfunction addChatMsg(name, avatar, text, type, id) {\n  if (id && msgIds.has(id)) return;\n  if (id) msgIds.add(id);\n\n  const msgs = document.getElementById('messages');\n  const div = document.createElement('div');\n  div.className = 'msg ' + type;\n\n  const nameLabel = type === 'agent' ? '◆ ClaudeOS' : name;\n  div.innerHTML =\n    '<div class=\"avatar\">' + esc(avatar || '?') + '</div>' +\n    '<div>' +\n      '<div class=\"name\">' + esc(nameLabel) + '</div>' +\n      '<div class=\"bubble\">' + esc(text) + '</div>' +\n    '</div>';\n\n  msgs.appendChild(div);\n  msgs.scrollTop = msgs.scrollHeight;\n}\n\nfunction addSystemMsg(text) {\n  const msgs = document.getElementById('messages');\n  const div = document.createElement('div');\n  div.className = 'system-msg';\n  div.textContent = '— ' + text + ' —';\n  msgs.appendChild(div);\n  msgs.scrollTop = msgs.scrollHeight;\n}\n\nfunction updatePeerCount() {\n  const online = Object.values(peers).filter(p => p.dc?.readyState === 'open').length;\n  document.getElementById('peerCount').textContent = online + ' online';\n  if (online > 0) document.getElementById('statusDot').className = 'dot online';\n}\n\nfunction cleanupPeer(id) {\n  if (peers[id]) {\n    if (peers[id].dc) try { peers[id].dc.close(); } catch {}\n    if (peers[id].pc) try { peers[id].pc.close(); } catch {}\n    delete peers[id];\n  }\n}\n\nfunction disconnect() {\n  Object.keys(peers).forEach(cleanupPeer);\n  if (socket) { try { socket.disconnect(); } catch {} socket = null; }\n  document.getElementById('chatScreen').style.display = 'none';\n  document.getElementById('setupScreen').style.display = 'flex';\n  document.getElementById('statusDot').className = 'dot';\n}\n\nfunction esc(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }\n\n// Auto-resize textarea\ndocument.getElementById('chatInput')?.addEventListener('input', function() {\n  this.style.height = 'auto';\n  this.style.height = Math.min(this.scrollHeight, 80) + 'px';\n});\n\n// Init\nloadProfile();\ncheckUrlParams();\n\n// Auto-join if URL has room param\nconst autoRoom = new URLSearchParams(window.location.search).get('room');\nif (autoRoom && document.getElementById('nameInput').value) {\n  document.getElementById('roomInput').value = autoRoom;\n  // Small delay for DOM\n  setTimeout(() => {\n    if (document.getElementById('nameInput').value) joinRoom();\n  }, 100);\n}\n</script>\n\n\n<veepn-lock-screen><template shadowrootmode=\"open\"><style>html{box-sizing:border-box;text-size-adjust:100%;word-break:normal;tab-size:4}*,:before,:after{background-repeat:no-repeat;box-sizing:border-box}:before,:after{text-decoration:inherit;vertical-align:inherit}*{padding:0;margin:0}hr{overflow:visible;height:0;color:inherit;border:0;border-top:1px solid}details,main{display:block}summary{display:list-item}small{font-size:80%}[hidden]{display:none!important}abbr[title]{border-bottom:none;text-decoration:underline;text-decoration:underline dotted}a{background-color:transparent}a:active,a:hover{outline-width:0}code,kbd,pre,samp{font-family:monospace}pre{font-size:1em}b,strong{font-weight:bolder}sub,sup{font-size:75%;line-height:0;position:relative;vertical-align:baseline}sub{bottom:-.25em}sup{top:-.5em}table{border-color:inherit;text-indent:0}iframe{border-style:none}input{border-radius:0}[type=number]::-webkit-inner-spin-button,[type=number]::-webkit-outer-spin-button{height:auto}[type=search]{appearance:textfield;outline-offset:-2px}[type=search]::-webkit-search-decoration{appearance:none}textarea{overflow:auto;resize:vertical}button,input,optgroup,select,textarea{font:inherit;color:inherit}optgroup{font-weight:700}button{overflow:visible}button,select{text-transform:none}button,[type=button],[type=reset],[type=submit],[role=button]{cursor:pointer}button::-moz-focus-inner,[type=button]::-moz-focus-inner,[type=reset]::-moz-focus-inner,[type=submit]::-moz-focus-inner{border-style:none;padding:0}button,html [type=button],[type=reset],[type=submit]{appeara